pipeline {
  agent any

  environment {
    APP_REPO = 'https://github.com/furqan137/PostManager.git'
    APP_IMAGE = 'postmanager-app'
    TEST_IMAGE = 'postmanager-tests'
    APP_CONTAINER = 'postmanager-running'
    APP_PORT = '3000'
  }

  stages {
    stage('Checkout Code') {
      steps {
        git branch: 'main', url: "${APP_REPO}"
      }
    }

    stage('Build Application Docker Image') {
      steps {
        dir('app') {
          sh 'docker build -t ${APP_IMAGE} .'
        }
      }
    }

    stage('Build Test Docker Image') {
      steps {
        dir('tests') {
          sh 'docker build -t ${TEST_IMAGE} .'
        }
      }
    }

    stage('Start Application Container') {
      steps {
        script {
          sh """
            docker rm -f ${APP_CONTAINER} || true
            docker run -d --name ${APP_CONTAINER} -p ${APP_PORT}:3000 ${APP_IMAGE}
            echo "⏳ Waiting for app to be ready..."
            sleep 30
          """
        }
      }
    }

    stage('Run Tests') {
      steps {
        sh 'docker run --rm --network host ${TEST_IMAGE}'
      }
    }
  }

  post {
    success {
      script {
        def email = sh(script: "git --no-pager show -s --format='%ae' HEAD", returnStdout: true).trim()
        emailext (
          subject: "✅ PostManager CI Success: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
          body: "✅ The build and tests passed successfully.\n\nDetails: ${env.BUILD_URL}",
          to: email
        )
      }
    }

    failure {
      script {
        def email = sh(script: "git --no-pager show -s --format='%ae' HEAD", returnStdout: true).trim()
        emailext (
          subject: "❌ PostManager CI Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
          body: "❌ The build or tests failed.\n\nSee logs: ${env.BUILD_URL}",
          to: email,
          attachLog: true
        )
      }
    }
  }
}
